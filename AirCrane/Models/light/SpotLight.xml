<?xml version="1.0" encoding="ISO-8859-1"?>

<PropertyList>

  <!-- ================================================================== -->
  <!-- Basic Lighting                                                     -->
  <!-- ================================================================== -->
  <model>
    <name>spotlightfrontDEF</name>
    <path>Aircraft/AirCrane/Models/light/DEFAULT/SpotLightFront.xml</path>
    <offsets>
      <x-m> -9.92556 </x-m>
      <y-m>  0.10741 </y-m>
      <z-m> -2.79311 </z-m>
      <pitch-deg> -105 </pitch-deg>
    </offsets>
  </model>
  <model>
    <name>spotlightrearDEF</name>
    <path>Aircraft/AirCrane/Models/light/DEFAULT/SpotLightRear.xml</path>
    <offsets>
      <x-m> -7.78415 </x-m>
      <y-m>  0.00000 </y-m>
      <z-m> -3.21645 </z-m>
      <pitch-deg> -105 </pitch-deg>
    </offsets>
  </model>

  <animation>
    <type>select</type>
    <object-name>spotlightfrontDEF</object-name>
    <object-name>spotlightrearDEF</object-name>
    <condition>
      <not><property>/sim/rendering/shaders/skydome</property></not>
    </condition>
  </animation>

  <!-- ================================================================== -->
  <!-- ALS Lighting                                                       -->
  <!-- ================================================================== -->
  
  <model>
    <name>spotlightfrontALS</name>
    <path>Aircraft/AirCrane/Models/light/ALS/SpotLightFront.xml</path>
  </model>
  <model>
    <name>spotlightrearALS</name>
    <path>Aircraft/AirCrane/Models/light/ALS/SpotLightRear.xml</path>
  </model>
 
  <animation>
    <type>select</type>
    <object-name>spotlightfrontALS</object-name>
    <object-name>spotlightrearALS</object-name>
    <condition>
      <property>/sim/rendering/shaders/skydome</property>
    </condition>
  </animation>

</PropertyList>
