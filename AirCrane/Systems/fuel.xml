<?xml version="1.0" encoding="ISO-8859-1"?>

<PropertyList>

    <!-- fwd tank temperature -->
    <filter>
      <name>Fuel Temp Tank Fwd</name>
      <type>noise-spike</type>
      <max-rate-of-change>0.05</max-rate-of-change>

      <enable>
        <property>/systems/fuel/temp-start-calc</property>
      </enable>

      <input>
        <property>/environment/temperature-degf</property>
      </input>

      <output>
        <property>/systems/fuel/tank[0]/temp</property>
      </output>
    </filter>

    <!-- aft tank temperature -->
    <filter>
      <name>Fuel Temp Tank Aft</name>
      <type>noise-spike</type>
      <max-rate-of-change>0.05</max-rate-of-change>

      <enable>
        <property>/systems/fuel/temp-start-calc</property>
      </enable>

      <input>
        <property>/environment/temperature-degf</property>
      </input>

      <output>
        <property>/systems/fuel/tank[1]/temp</property>
      </output>
    </filter>
    <!-- aux tank temperature -->
    <filter>
      <name>Fuel Temp Tank Aux</name>
      <type>noise-spike</type>
      <max-rate-of-change>0.05</max-rate-of-change>

      <enable>
        <property>/systems/fuel/temp-start-calc</property>
      </enable>

      <input>
        <property>/environment/temperature-degf</property>
      </input>

      <output>
        <property>/systems/fuel/tank[2]/temp</property>
      </output>
    </filter>

    <!-- Engine 1 heater ON -->
    <logic>
      <name>Fuel Heat Eng1 On</name>
      <input>
        <and>
          <greater-than>
            <property>systems/electrical/outputs/main-left/fuel-heat-eng1</property>
            <value>20.0</value>
          </greater-than>
          <property>controls/switches/fuelheatereng1</property>
        </and>
      </input>
      <input><value>0</value></input>
      <output>
        <property>systems/fuel/heat-eng1-on</property>
      </output>
    </logic>

    <!-- Engine 2 heater ON -->
    <logic>
      <name>Fuel Heat Eng2 On</name>
      <input>
        <and>
          <greater-than>
            <property>systems/electrical/outputs/main-right/fuel-heat-eng2</property>
            <value>20.0</value>
          </greater-than>
          <property>controls/switches/fuelheatereng2</property>
        </and>
      </input>
      <input><value>0</value></input>
      <output>
        <property>systems/fuel/heat-eng2-on</property>
      </output>
    </logic>
    
    <!-- Engine 1 fuel line temperature -->
    <filter>
      <name>Fuel Temp Line Eng1</name>
      <type>noise-spike</type>
      <max-rate-of-change>0.5</max-rate-of-change>

      <enable>
        <property>/systems/fuel/temp-start-calc</property>
      </enable>

      <input>
        <expression>
          <sum>
            <!-- Base: forward tank temp -->
            <property>/systems/fuel/tank[0]/temp</property>

            <!-- Heater adds +60°F when ON -->
            <product>
              <property>/systems/fuel/heat-eng1-on</property>
              <value>60</value>
            </product>
          </sum>
        </expression>
      </input>

      <output>
        <property>/systems/fuel/temp-line-eng1</property>
      </output>
    </filter>

    <!-- Engine 2 fuel line temperature -->
    <filter>
      <name>Fuel Temp Line Eng2</name>
      <type>noise-spike</type>
      <max-rate-of-change>0.5</max-rate-of-change>

      <enable>
        <property>/systems/fuel/temp-start-calc</property>
      </enable>

      <input>
        <expression>
          <sum>
            <!-- Base: aft tank temp -->
            <property>/systems/fuel/tank[1]/temp</property>

            <!-- Heater adds +60°F when ON -->
            <product>
              <property>/systems/fuel/heat-eng2-on</property>
              <value>60</value>
            </product>
          </sum>
        </expression>
      </input>

      <output>
        <property>/systems/fuel/temp-line-eng2</property>
      </output>
    </filter>

    <filter>
      <name>Bell Temp Eng1</name>
      <type>noise-spike</type>
      <max-rate-of-change>1000</max-rate-of-change> <!-- effectively instant -->
      <enable><value>1</value></enable>

      <input>
        <property>systems/fuel/temp-line-eng1</property>
      </input>

      <output>
        <property>systems/fuel/belltemp-eng1</property>
      </output>
    </filter>

    <filter>
      <name>Bell Temp Eng2</name>
      <type>noise-spike</type>
      <max-rate-of-change>1000</max-rate-of-change>
      <enable><value>1</value></enable>

      <input>
        <property>systems/fuel/temp-line-eng2</property>
      </input>

      <output>
        <property>systems/fuel/belltemp-eng2</property>
      </output>
    </filter>

